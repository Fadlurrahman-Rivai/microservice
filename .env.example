# ─────────────────────────────────────────────────────────────
# MarketPlace Microservices – Environment Variables
# Salin file ini menjadi .env lalu isi sesuai kebutuhan:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Database Credentials
DB_ROOT_PASSWORD=your_root_password
DB_USER=marketplace_user
DB_PASSWORD=your_db_password

# Service Ports (host-side)
FRONTEND_PORT=8080
CATALOG_PORT=8001
CART_PORT=8002
INVENTORY_PORT=8003
PAYMENT_PORT=8004
